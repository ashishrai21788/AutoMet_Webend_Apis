# MongoDB Connection (one database for both driver and user apps; see COLLECTIONS_OVERVIEW.md)
MONGODB_USERNAME=your_username
MONGODB_PASSWORD=your_password
MONGODB_CLUSTER=your_cluster.mongodb.net
DB_NAME=api_database
# Default driver collection name (used by models/driver.js; other collections are fixed in code)
COLLECTION_NAME=drivers

# Server Configuration
PORT=3000
# HOST=0.0.0.0
# NODE_ENV=development

# JWT (driver/user auth; used by userController, otpController, dynamicController)
JWT_SECRET=your_super_secret_jwt_key_for_driver_authentication_2024

# Cloudinary (image uploads; used by config/cloudinary.js)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Alternative: single URL (optional; app uses the three vars above)
# CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# ---------------------------------------------------------------------------
# Optional: Firebase / Firestore (used by config/firestore.js; non-blocking)
# Set one of the following. If none set, Firestore is skipped with a warning.
# ---------------------------------------------------------------------------
# Option 1: Service account JSON string (recommended for production)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Option 2: Path to service account JSON file (project key file)
FIREBASE_SERVICE_ACCOUNT_PATH=./automet-89e4b-firebase-adminsdk-fbsvc-973c0f0fdd.json
# Option 3: Google default credentials
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
# Option 4: Project ID only (development)
# FIREBASE_PROJECT_ID=your-project-id
# Firestore drivers collection name (default: drivers)
# FIRESTORE_DRIVERS_COLLECTION=drivers
